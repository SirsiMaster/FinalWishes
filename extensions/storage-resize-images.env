IMG_SIZES=200x200,800x800
IMG_BUCKET=${param:PROJECT_ID}.firebasestorage.app
RESIZED_IMAGES_PATH=
INCLUDE_PATH_LIST=estates/{estateId}/vault,estates/{estateId}/memoirs
EXCLUDE_PATH_LIST=
CACHE_CONTROL_HEADER=
IS_ANIMATED=false
SHARP_OPTIONS=
OUTPUT_OPTIONS={}
IMAGE_TYPE=jpeg,png,webp
MAKE_PUBLIC=no
OUTPUT_CSV_BUCKET=
FAILED_IMAGES_PATH=_failed
DELETE_ORIGINAL_FILE=false
DO_BACKFILL=false
LOCATION=us-central1
