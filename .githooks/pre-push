#!/bin/bash
# 𓆄 Ma'at Pre-Push Gate (FinalWishes)
# Quality, truth, and order — the feather weighs before every push.
# Install: git config core.hooksPath .githooks
# Skip:    git push --no-verify (use sparingly)

set -e

echo ""
echo "  𓆄 Ma'at pre-push gate... [FinalWishes]"
echo ""

# 1. Lint check
if ! npm run lint 2>/dev/null; then
    echo "  ❌ npm run lint failed — fix errors before pushing"
    exit 1
fi

# 2. Typecheck check
if ! npm run typecheck 2>/dev/null; then
    echo "  ❌ npm run typecheck failed"
    exit 1
fi

# 3. Build check
if ! npm run build 2>/dev/null; then
    echo "  ❌ npm run build failed"
    exit 1
fi

echo "  ✅ Ma'at: the feather weighs true — pushing FinalWishes"
echo ""
