#!/bin/bash
# 𓆄 Ma'at Pre-Push Gate (FinalWishes)
# Quality, truth, and order — the feather weighs before every push.
# Install: git config core.hooksPath .githooks
# Skip:    git push --no-verify (use sparingly)

set -e

echo ""
echo "  𓆄 Ma'at pre-push gate... [FinalWishes]"
echo ""

# 1. Lint check
if ! npm run lint 2>/dev/null; then
    echo "  ❌ npm run lint failed — fix errors before pushing"
    exit 1
fi

# 2. Typecheck check
if ! npm run typecheck 2>/dev/null; then
    echo "  ❌ npm run typecheck failed"
    exit 1
fi

# 3. Web unit tests (vitest) — matches CI 'Web - Test (Vitest)'
if ! ( cd web && npx vitest run ) 2>/dev/null; then
    echo "  ❌ web vitest failed — fix failing tests before pushing"
    exit 1
fi

# 4. Build check
if ! npm run build 2>/dev/null; then
    echo "  ❌ npm run build failed"
    exit 1
fi

# 5. Committed-secrets scan (gitleaks) — Credential & Secret Safety Law (2026-06-30).
# Scans only the commit range being pushed. Skips gracefully if gitleaks is not
# installed locally; CI ("Security - Secrets Scan") still gates every PR regardless.
if command -v gitleaks >/dev/null 2>&1; then
    echo "  → scanning for committed secrets (gitleaks)..."
    ZERO="0000000000000000000000000000000000000000"
    RANGE=""
    while read -r local_ref local_sha remote_ref remote_sha; do
        [ "$local_sha" = "$ZERO" ] && continue
        if [ "$remote_sha" = "$ZERO" ]; then
            RANGE="$local_sha"          # new branch: scan its whole log once
        else
            RANGE="${RANGE:+$RANGE }${remote_sha}..${local_sha}"
        fi
    done
    if [ -n "$RANGE" ]; then
        for r in $RANGE; do
            gitleaks detect --log-opts="$r" --no-banner --redact \
                || { echo "  ❌ gitleaks found a committed secret in $r — fix before pushing. Do NOT --no-verify past this."; exit 1; }
        done
    fi
else
    echo "  ⚠ gitleaks not installed — secret scan SKIPPED (brew install gitleaks). CI still gates this."
fi

echo "  ✅ Ma'at: the feather weighs true — pushing FinalWishes"
echo ""
