# FinalWishes Environment Variables
# Copy this file to .env and fill in values for local development.
# Production values are set in Cloud Run environment configuration.

# ── Core ──
GOOGLE_CLOUD_PROJECT=              # GCP project ID (e.g., finalwishes-prod)
PORT=8080                          # API server port (default: 8080)

# ── Demo Mode ──
DEMO_MODE=false                    # Set to "true" to enable demo-token auth bypass (NEVER in production)

# ── Cloud SQL (PII Vault) ──
CLOUD_SQL_CONNECTION=              # Cloud SQL instance connection name (e.g., finalwishes-prod:us-central1:finalwishes-pii-vault)
VAULT_DB_PASSWORD=                 # PostgreSQL vault_admin password (stored in Secret Manager in production)
VAULT_DB_HOST=                     # For local dev with Cloud SQL Proxy (e.g., 127.0.0.1)

# ── Cloud Storage ──
VAULT_STORAGE_BUCKET=              # Cloud Storage bucket for document vault (e.g., finalwishes-vault)

# ── Stripe Payments ──
STRIPE_SECRET_KEY=                 # Stripe secret key (sk_test_... or sk_live_...)
STRIPE_WEBHOOK_SECRET=             # Stripe webhook signing secret (whsec_...)
STRIPE_PUBLISHABLE_KEY=            # Stripe publishable key (pk_test_... or pk_live_...)
STRIPE_SUCCESS_URL=                # Redirect after successful checkout (e.g., https://finalwishes-prod.web.app/estates/{ESTATE_ID}/settings?payment=success)
STRIPE_CANCEL_URL=                 # Redirect after cancelled checkout

# ── AI / Shepherd ──
GEMINI_API_KEY=                    # Google Gemini API key (fallback AI provider)

# ── OpenSign (E-Signatures via Sirsi Sign) ──
OPENSIGN_API_KEY=                  # OpenSign API key
OPENSIGN_API_URL=                  # OpenSign API base URL (e.g., https://sign.sirsi.ai)
OPENSIGN_CREATE_ENVELOPE_URL=      # OpenSign envelope creation endpoint
OPENSIGN_WEBHOOK_SECRET=           # OpenSign webhook signing secret

# ── Time Capsules ──
CAPSULE_DELIVERY_URL=              # Cloud Tasks delivery endpoint for time capsule messages

# ── Speech-to-Text ──
SPEECH_LOCATION=                   # Google Cloud Speech-to-Text region (e.g., us-central1)
