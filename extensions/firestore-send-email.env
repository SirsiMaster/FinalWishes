## ── FinalWishes Email Extension ──────────────────────────────
## Uses Google Workspace SMTP Relay (smtp-relay.gmail.com)
## instead of SendGrid. Zero additional vendor cost.
##
## SETUP REQUIRED (one-time, in Google Workspace Admin):
##   1. Admin Console → Apps → Google Workspace → Gmail → Routing
##   2. Add SMTP relay service:
##      - Allowed senders: Only addresses in my domains (sirsi.ai)
##      - Authentication: Require SMTP authentication
##      - Encryption: Require TLS
##   3. Create an App Password for noreply@sirsi.ai:
##      - Google Account → Security → 2-Step Verification → App Passwords
##      - Store the password in Firebase Secret Manager as SMTP_PASSWORD
##   4. Redeploy: firebase deploy --only extensions
## ─────────────────────────────────────────────────────────────

SMTP_CONNECTION_URI=smtps://noreply@sirsi.ai:${param:SMTP_PASSWORD}@smtp-relay.gmail.com:465
SMTP_PASSWORD=
MAIL_COLLECTION=mail
DEFAULT_FROM=FinalWishes <noreply@sirsi.ai>
DEFAULT_REPLY_TO=support@sirsi.ai
USERS_COLLECTION=
TEMPLATES_COLLECTION=email_templates
TESTING=
LOCATION=us-central1
DATABASE_REGION=nam5
