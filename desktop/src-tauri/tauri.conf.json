// FinalWishes Desktop — Tauri Configuration
{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:3000",
    "distDir": "../web/dist"
  },
  "package": {
    "productName": "FinalWishes",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": { "open": true },
      "fs": { "readFile": true, "writeFile": true, "scope": ["$APPDATA/**"] },
      "dialog": { "open": true, "save": true },
      "notification": { "all": true }
    },
    "bundle": {
      "active": true,
      "identifier": "ai.sirsi.finalwishes",
      "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.icns"],
      "targets": "all",
      "macOS": {
        "minimumSystemVersion": "13.0",
        "frameworks": []
      }
    },
    "security": {
      "csp": "default-src 'self'; connect-src https://api.finalwishes.app https://legacy-estate-os.web.app https://*.googleapis.com"
    },
    "windows": [
      {
        "title": "FinalWishes — The Estate Operating System",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ]
  }
}
